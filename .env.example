# Copy this file to .env and adjust values as needed.
# .env is gitignored - do not commit real credentials.

# Postgres credentials shared by the db and app services (local-dev defaults
# shown; override for anything beyond local use).
POSTGRES_DB=bank_categorizer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host-side port for Postgres. Defaults to 5433 because 5432 may already be
# taken by another local Postgres container/instance.
DB_HOST_PORT=5433

# Host-side port for the app.
APP_PORT=8080

# Host-side port for the frontend (Nginx serving the built SPA).
FRONTEND_PORT=3000
