# Copy this file to .env (gitignored) and adjust values as needed.

# Base URL of the backend API (see src/main/java/com/bankcategorizer, run via
# `mvn spring-boot:run`, defaults to http://localhost:8080). Never hardcode this
# in source - all API calls read it from import.meta.env.VITE_API_BASE_URL.
VITE_API_BASE_URL=http://localhost:8080
